msgid "`rustup show`"
msgstr ""

#: src/examples.md:16
msgid "Show which toolchain will be used in the current directory"
msgstr ""

#: src/examples.md:17
msgid "`rustup toolchain uninstall nightly`"
msgstr ""

#: src/examples.md:17
msgid "Uninstall a given toolchain"
msgstr ""

