msgid "`rustup target add arm-linux-androideabi`"
msgstr ""

#: src/examples.md:8
msgid "Install the Android target"
msgstr ""

#: src/examples.md:9
msgid "`rustup target remove arm-linux-androideabi`"
msgstr ""

#: src/examples.md:9
msgid "Remove the Android target"
msgstr ""

#: src/examples.md:10
msgid "`rustup run nightly rustc foo.rs`"
msgstr ""

#: src/examples.md:10
msgid "Run the nightly regardless of the active toolchain"
msgstr ""

#: src/examples.md:11
msgid "`rustc +nightly foo.rs`"
msgstr ""

#: src/examples.md:11
msgid ""
"[Shorthand](overrides.md#toolchain-override-shorthand) way to run a nightly "
"compiler"
msgstr ""

#: src/examples.md:12
msgid "`rustup run nightly bash`"
msgstr ""

#: src/examples.md:12
msgid "Run a shell configured for the nightly compiler"
msgstr ""

#: src/examples.md:13
msgid "`rustup default stable-msvc`"
msgstr ""

#: src/examples.md:13
msgid "On Windows, use the MSVC toolchain instead of GNU"
msgstr ""

