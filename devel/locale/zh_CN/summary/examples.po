msgid "`rustup default nightly`"
msgstr ""

#: src/examples.md:5
msgid ""
"Set the [default toolchain](overrides.md#default-toolchain) to the latest "
"nightly"
msgstr ""

#: src/examples.md:6
msgid "`rustup set profile minimal`"
msgstr ""

#: src/examples.md:6
msgid "Set the default [profile](concepts/profiles.md)"
msgstr ""

#: src/examples.md:7
msgid "`rustup target list`"
msgstr ""

#: src/examples.md:7
msgid ""
"List all available [targets](cross-compilation.md) for the active toolchain"
msgstr ""

